# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# Database
DATABASE_URL=mysql://kongkwun:kongkwun_pass@localhost:3306/kongkwun_bot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Google Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
GCS_KEY_FILE=./gcs-key.json   # service account key (local dev only)

# Server
PORT=3000
NODE_ENV=development
