# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# Database
DATABASE_URL=mysql://kongkwun:kongkwun_pass@localhost:3306/kongkwun_bot

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# --- LEGACY: Google Cloud Storage (kept for rollback, see legacy/pre-minio/README.md) ---
# GCS_BUCKET_NAME=your-bucket-name
# GCS_KEY_FILE=./gcs-key.json   # service account key (local dev only)

# --- S3 / MinIO ---
# S3_ENDPOINT  = host the APP uses (in-network).
#   docker compose: http://minio:9000
#   k8s:            http://minio.<namespace>.svc.cluster.local:9000
# S3_PUBLIC_ENDPOINT = host the BROWSER uses (presigned URL host).
#   dev:  http://localhost:9000
#   prod: https://media.example.com
# IMPORTANT: SigV4 signs the Host header — if S3_PUBLIC_ENDPOINT doesn't match
# the host the browser actually requests, presigned URLs will 403 with
# SignatureDoesNotMatch. Leave unset to fall back to S3_ENDPOINT.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kongkwun-media

# Server
PORT=3000
NODE_ENV=development
